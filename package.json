{
  "name": "screenshot-to-shadcn",
  "version": "1.0.0",
  "description": "Turn any UI screenshot into editable Figma designs with proper Shadcn components",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build --mode main && vite build && mv dist/src/ui/index.html dist/ui.html && rm -rf dist/src",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.plugin.json"
  },
  "keywords": [
    "figma",
    "plugin",
    "shadcn",
    "screenshot",
    "ui"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@figma/plugin-typings": "^1.100.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.300.0",
    "postcss": "^8.4.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-singlefile": "^0.13.5"
  }
}
